{
  "name": "resume",
  "version": "0.0.0",
  "repository": "https://github.com/HyunSeob/resume.git",
  "author": "HyunSeob <mail@hyunseob.me>",
  "license": "MIT",
  "scripts": {
    "start": "parcel src/index.html",
    "build": "rm -rf dist && parcel build --no-cache -d dist --public-url /resume src/index.html",
    "check:analytics": "node scripts/check-analytics.js",
    "check:dist": "node scripts/check-dist.js",
    "check:site": "yarn check:analytics && yarn build && yarn check:dist"
  },
  "dependencies": {
    "normalize.css": "^8.0.0",
    "spoqa-han-sans": "^2.1.2"
  },
  "devDependencies": {
    "autoprefixer": "^9.1.5",
    "cssnano": "^4.1.4",
    "parcel-bundler": "^1.12.5",
    "postcss-modules": "^1.4.1"
  }
}
