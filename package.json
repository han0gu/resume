{
  "name": "resume",
  "version": "0.0.0",
  "repository": "https://github.com/HyunSeob/resume.git",
  "author": "HyunSeob <mail@hyunseob.me>",
  "license": "MIT",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node scripts/run-site.js --mode=serve",
    "build": "node scripts/run-site.js --mode=build",
    "check:analytics": "node scripts/check-analytics.js",
    "check:runtime": "node scripts/check-run-site.js",
    "check:export": "node scripts/check-export-pdf.js",
    "check:print": "node scripts/check-print-css.js",
    "check:dist": "node scripts/check-dist.js",
    "check:site": "yarn check:analytics && yarn check:runtime && yarn build && yarn check:dist",
    "export:pdf:a4-print": "yarn build && node scripts/export-pdf.js --preset=a4-print",
    "export:pdf:desktop-long-canvas": "yarn build && node scripts/export-pdf.js --preset=desktop-long-canvas",
    "export:pdf:mobile-long-canvas": "yarn build && node scripts/export-pdf.js --preset=mobile-long-canvas",
    "export:pdf:all": "yarn build && node scripts/export-pdf.js --preset=all"
  },
  "dependencies": {
    "normalize.css": "^8.0.0",
    "spoqa-han-sans": "^2.1.2"
  },
  "devDependencies": {
    "autoprefixer": "^9.1.5",
    "cssnano": "^4.1.4",
    "deasync": "0.1.24",
    "parcel-bundler": "^1.12.5",
    "playwright-core": "^1.59.1",
    "postcss-modules": "^1.4.1"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
